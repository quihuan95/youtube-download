{
  "name": "tool-video",
  "version": "1.0.0",
  "description": "YouTube video downloader with quality, MP3, and trim",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "node server.js",
    "dev:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --watch",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --minify",
    "start": "npm run build:css && node server.js",
    "stop": "npx --yes kill-port 3008",
    "docker:build": "docker build -t tool-video .",
    "docker:run": "docker run --rm -p 3000:3000 -e HOST=0.0.0.0 tool-video",
    "pm2:start": "npm run build:css && pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart tool-video",
    "pm2:logs": "pm2 logs tool-video"
  },
  "dependencies": {
    "express": "^5.1.0",
    "youtube-dl-exec": "^3.0.22"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tailwindcss": "^3.4.17"
  }
}
